authentik_url   = "https://auth.example.com"
authentik_token = "your-api-token"

admins = {
  alice = {
    username     = "alice"
    name         = "Alice"
    groups       = ["admins"]
    admin_groups = ["photos"]
  }
}

admin_emails = {
  alice = "alice@example.com"
}

users = {
  bob = {
    username = "bob"
    name     = "Bob"
    groups   = ["users", "photos"]
  }
  carol = {
    username = "carol"
    name     = "Carol"
    groups   = ["users", "photos"]
  }
}

user_emails = {
  bob   = "bob@example.com"
  carol = "carol@example.com"
}

service_accounts = {
  ldapservice = {
    username   = "ldapservice"
    name       = "ldapservice"
    groups     = []
    attributes = "{\"goauthentik.io/user/token-expires\": false}"
  }
}

groups = {
  admins = { is_superuser = true }
  users  = { is_superuser = false }
}

oauth2_providers = {
  git = {
    name                  = "Provider for Git"
    client_id             = "your-client-id"
    property_mappings     = ["xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"]
    allowed_redirect_uris = [{ url = "https://git.example.com/user/oauth2/authentik/callback" }]
    application_name      = "Git"
    application_slug      = "git"
    meta_launch_url       = "https://git.example.com"
    meta_description      = "Remote Code Repositories."
    meta_publisher        = ""
    meta_icon             = "application-icons/git.png"
    application_group     = "Home"
  }
  graphs = {
    name                  = "Provider for Graphs"
    client_id             = "your-client-id"
    property_mappings     = ["xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"]
    allowed_redirect_uris = [{ url = "https://graphs.example.com/login/generic_oauth" }]
    logout_method         = "frontchannel"
    logout_uri            = "https://graphs.example.com/logout"
    application_name      = "Graphs"
    application_slug      = "graphs"
    meta_launch_url       = ""
    meta_description      = "Dashboards."
    meta_publisher        = ""
    meta_icon             = "application-icons/graphs.svg"
    application_group     = "Home"
  }
  photos = {
    name              = "Provider for Photos"
    client_id         = "your-client-id"
    property_mappings = ["xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"]
    allowed_redirect_uris = [
      { url = "app.photos:///oauth-callback" },
      { url = "https://photos.example.com/auth/login" },
      { url = "https://photos.example.com/user-settings" },
    ]
    application_name  = "Photos"
    application_slug  = "photos"
    meta_launch_url   = "https://photos.example.com/auth/login?autoLaunch=1"
    meta_description  = "Self-hosted Photos."
    meta_publisher    = ""
    meta_icon         = "application-icons/photos.svg"
    application_group = "Home"
  }
  virt = {
    name              = "Provider for Virt"
    client_id         = "your-client-id"
    sub_mode          = "user_email"
    logout_uri        = "https://virt.example.com:8006/#"
    property_mappings = ["xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"]
    allowed_redirect_uris = [{ url = "https://virt.example.com:8006" }]
    application_name  = "Virt"
    application_slug  = "virt"
    meta_launch_url   = ""
    meta_description  = "Virtualisation."
    meta_publisher    = ""
    meta_icon         = "application-icons/virt.svg"
    application_group = "Home"
  }
}

proxy_providers = {
  proxy = {
    name                  = "Provider for Proxy"
    access_token_validity = "hours=24"
    external_host         = "https://proxy.example.com"
    mode                  = "forward_single"
    application_name      = "Proxy"
    application_slug      = "proxy"
    meta_launch_url       = ""
    meta_description      = "Reverse Proxy."
    meta_publisher        = ""
    meta_icon             = "application-icons/proxy.svg"
    application_group     = "Home"
  }
}

roles = {}
